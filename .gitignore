# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing an app that depends on specific versions, keeping it in lock is standard.
#   For this repository, keep Pipfile and ignore Pipfile.lock only if standard.

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally tracked.

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally tracked.
.pdm-plugins/
.pdm-python

# PEP 582; project local packages (virtualenv)
__pypackages__/

